#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
codex-result — Extract structured data from Codex JSONL output.

Usage:
  codex-result <mode> <jsonl-file>
  codex-result <mode>                  (reads from stdin)

Modes:
  last        Last agent message (targeted response)
  messages    All agent messages
  session-id  Thread/session ID
  usage       Token counts (JSON)
  commands    Commands run with exit codes (JSON, one per line)
  reasoning   Reasoning/thinking summaries (may be empty with current Codex CLI builds)
  summary     Session ID + token usage + last message (compact overview)

Examples:
  codex-result last /tmp/codex-out.jsonl
  cat out.jsonl | codex-result session-id
  codex-result summary /tmp/codex-out.jsonl
USAGE
}

if [[ $# -lt 1 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  usage
  exit 0
fi

mode="$1"
shift

# Read from file arg or stdin
input="${1:-/dev/stdin}"

case "$mode" in
  last)
    jq -rs '[.[] | select(.type=="item.completed" and .item.type=="agent_message") | .item.text] | last' "$input"
    ;;
  messages)
    jq -r 'select(.type=="item.completed" and .item.type=="agent_message") | .item.text' "$input"
    ;;
  session-id)
    jq -r 'select(.type=="thread.started") | .thread_id' "$input"
    ;;
  usage)
    jq 'select(.type=="turn.completed") | .usage' "$input"
    ;;
  commands)
    jq 'select(.type=="item.completed" and .item.type=="command_execution") | {cmd: .item.command, exit: .item.exit_code, out: .item.aggregated_output}' "$input"
    ;;
  reasoning)
    jq -r 'select(.type=="item.completed" and .item.type=="reasoning") | .item.text' "$input"
    ;;
  summary)
    echo "SESSION: $(jq -r 'select(.type=="thread.started") | .thread_id' "$input")"
    echo "TOKENS: $(jq -c 'select(.type=="turn.completed") | .usage | {in: .input_tokens, out: .output_tokens, cached: .cached_input_tokens}' "$input")"
    echo "---"
    jq -rs '[.[] | select(.type=="item.completed" and .item.type=="agent_message") | .item.text] | last' "$input"
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    usage >&2
    exit 1
    ;;
esac
