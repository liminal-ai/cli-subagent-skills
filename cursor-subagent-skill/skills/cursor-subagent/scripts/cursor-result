#!/usr/bin/env bash
set -euo pipefail

CURSOR_PROJECTS_DIR="${CURSOR_PROJECTS_DIR:-$HOME/.cursor/projects}"
RAW_JSON=false
CWD_OVERRIDE=""

usage() {
  cat <<'USAGE'
cursor-result — Run Cursor Agent safely and extract structured data from saved sessions.

Usage:
  cursor-result [--json] [--cwd <path>] exec "prompt" [cursor-agent flags...]
  cursor-result [--cwd <path>] <mode> [session-id]

Modes:
  exec          Run `cursor-agent -p --output-format stream-json` and print the normalized final assistant text by default
  last          Last assistant text message
  messages      All assistant text messages
  session-id    Latest session ID for the cwd, or echo the passed session ID if found
  session-file  Path to the saved Cursor transcript JSONL
  stream-file   Path to the saved stream JSONL produced by cursor-result exec
  tools         Tool calls with names and inputs (JSON, one per line)
  commands      Shell command attempts with completion data (JSON, one per line)
  reasoning     Reasoning text if emitted by the runtime
  usage         Usage object from the final result (JSON)
  summary       Session ID + model + usage + last message

Global flags:
  --json        For `exec`, print a normalized JSON object with session_id/result/model/usage/session_file/stream_file
  --cwd <path>  Resolve sessions and run exec in a different working directory

Examples:
  cursor-result exec "Fix the bug in main.ts"
  cursor-result exec "Plan the migration" --mode plan
  cursor-result exec "Implement the change" --trust --force
  cursor-result session-id
  cursor-result summary
USAGE
}

need_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: required command not found: $1" >&2
    exit 1
  fi
}

project_cwd() {
  if [[ -n "$CWD_OVERRIDE" ]]; then
    printf '%s\n' "$CWD_OVERRIDE"
  else
    pwd -P
  fi
}

project_slug() {
  local cwd
  cwd="$(project_cwd)"
  cwd="${cwd#/}"
  printf '%s\n' "${cwd//\//-}"
}

project_dir() {
  printf '%s\n' "$CURSOR_PROJECTS_DIR/$(project_slug)"
}

sanitize_json_stream() {
  perl -0pe '
    s/\e\][^\a]*(?:\a|\e\\)//gs;
    s/\eP(?:.|\n)*?\e\\//gs;
    s/\e\[[0-?]*[ -\/]*[@-~]//gs;
    s/\e[@-_]//gs;
    s/\r(?!\n)//g;
    s/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]//g;
  ' | awk '/^[[:space:]]*{/'
}

latest_session_id() {
  local dir="$(
    printf '%s\n' "$(project_dir)/agent-transcripts"
  )"

  if [[ ! -d "$dir" ]]; then
    echo "No Cursor transcript directory found for cwd: $(project_cwd)" >&2
    return 1
  fi

  shopt -s nullglob
  local files=("$dir"/*/*.jsonl)
  shopt -u nullglob

  local transcripts=()
  local file
  for file in "${files[@]}"; do
    if [[ "$file" != *.stream.jsonl ]]; then
      transcripts+=("$file")
    fi
  done

  if [[ ${#transcripts[@]} -eq 0 ]]; then
    echo "No Cursor transcripts found in: $dir" >&2
    return 1
  fi

  local latest
  latest="$(ls -t "${transcripts[@]}" 2>/dev/null | head -1 || true)"
  if [[ -z "$latest" ]]; then
    echo "No Cursor transcripts found in: $dir" >&2
    return 1
  fi

  basename "$latest" .jsonl
}

resolve_session_id() {
  local session_id="${1:-}"
  if [[ -n "$session_id" ]]; then
    local transcript
    transcript="$(transcript_file "$session_id")"
    local stream
    stream="$(stream_file "$session_id")"
    if [[ ! -f "$transcript" && ! -f "$stream" ]]; then
      echo "Session not found: $session_id" >&2
      return 1
    fi
    printf '%s\n' "$session_id"
  else
    latest_session_id
  fi
}

transcript_file() {
  local session_id="$1"
  printf '%s\n' "$(project_dir)/agent-transcripts/$session_id/$session_id.jsonl"
}

stream_file() {
  local session_id="$1"
  printf '%s\n' "$(project_dir)/agent-transcripts/$session_id/$session_id.stream.jsonl"
}

resolve_transcript_file() {
  local session_id
  session_id="$(resolve_session_id "${1:-}")" || return 1
  local path
  path="$(transcript_file "$session_id")"
  if [[ ! -f "$path" ]]; then
    echo "Cursor transcript not found: $session_id" >&2
    return 1
  fi
  printf '%s\n' "$path"
}

resolve_stream_file() {
  local session_id
  session_id="$(resolve_session_id "${1:-}")" || return 1
  local path
  path="$(stream_file "$session_id")"
  if [[ ! -f "$path" ]]; then
    echo "Cursor stream file not found for session: $session_id" >&2
    return 1
  fi
  printf '%s\n' "$path"
}

extract_last_text_stream() {
  local input="$1"
  jq -rs '[.[] | select(.type=="assistant") | .message.content[]? | select(.type=="text") | .text] | last // empty | sub("^[\\r\\n]+"; "") | sub("[\\r\\n]+$"; "")' "$input"
}

extract_messages_stream() {
  local input="$1"
  jq -r 'select(.type=="assistant") | .message.content[]? | select(.type=="text") | .text' "$input"
}

extract_last_text_transcript() {
  local input="$1"
  jq -rs '[.[] | select(.role=="assistant") | .message.content[]? | select(.type=="text") | .text] | last // empty | sub("^[\\r\\n]+"; "") | sub("[\\r\\n]+$"; "")' "$input"
}

extract_messages_transcript() {
  local input="$1"
  jq -r 'select(.role=="assistant") | .message.content[]? | select(.type=="text") | .text' "$input"
}

extract_tools_stream() {
  local input="$1"
  jq -c '
    select(.type=="tool_call" and .subtype=="started") as $evt
    | ($evt.tool_call | to_entries[0]) as $tc
    | {
        tool:
          (if $tc.key == "readToolCall" then "Read"
           elif $tc.key == "shellToolCall" then "Bash"
           elif $tc.key == "editToolCall" then "Edit"
           elif $tc.key == "globToolCall" then "Glob"
           elif $tc.key == "grepToolCall" then "Grep"
           else ($tc.key | sub("ToolCall$"; ""))
           end),
        input: (
          if $tc.key == "shellToolCall" then
            {
              command: $tc.value.args.command,
              description: ($tc.value.args.description // null),
              workingDirectory: ($tc.value.args.workingDirectory // null)
            }
          else
            ($tc.value.args // {})
          end
        ),
        id: $evt.call_id
      }' "$input"
}

normalized_exec_json() {
  local input="$1"
  local sid
  sid="$(jq -rs '[.[] | select(.type=="result") | .session_id] | last // empty' "$input")"
  local model
  model="$(jq -rs '[.[] | select(.type=="system" and .subtype=="init") | .model] | last // empty' "$input")"
  local result
  result="$(extract_last_text_stream "$input")"
  local usage
  usage="$(jq -sc '[.[] | select(.type=="result") | .usage] | last // {}' "$input")"
  local session_file=""
  local stream_file_path=""
  if [[ -n "$sid" ]]; then
    local transcript_candidate
    transcript_candidate="$(transcript_file "$sid")"
    local stream_candidate
    stream_candidate="$(stream_file "$sid")"
    if [[ -f "$transcript_candidate" ]]; then
      session_file="$transcript_candidate"
    fi
    if [[ -f "$stream_candidate" ]]; then
      stream_file_path="$stream_candidate"
    fi
  fi

  jq -n \
    --arg session_id "$sid" \
    --arg result "$result" \
    --arg model "$model" \
    --arg session_file "$session_file" \
    --arg stream_file "$stream_file_path" \
    --argjson usage "$usage" \
    '{
      session_id: $session_id,
      result: $result,
      model: $model,
      usage: $usage,
      session_file: (if $session_file == "" then null else $session_file end),
      stream_file: (if $stream_file == "" then null else $stream_file end)
    }'
}

run_exec() {
  need_command cursor-agent
  need_command jq

  if [[ $# -lt 1 ]]; then
    echo "Error: exec requires a prompt" >&2
    usage >&2
    exit 1
  fi

  local prompt="$1"
  shift

  local temp_raw
  temp_raw="$(mktemp "/tmp/cursor-result-raw.XXXXXX")"
  local temp_stream
  temp_stream="$(mktemp "/tmp/cursor-result.XXXXXX")"
  local exit_code=0

  (
    cd "$(project_cwd)"
    TERM=dumb NO_COLOR=1 CLICOLOR=0 FORCE_COLOR=0 cursor-agent -p --output-format stream-json --trust "$@" "$prompt" </dev/null >"$temp_raw"
  ) || exit_code=$?

  sanitize_json_stream <"$temp_raw" >"$temp_stream"

  local session_id
  session_id="$(jq -rs '[.[] | select(.type=="result") | .session_id] | last // empty' "$temp_stream")"

  if [[ -n "$session_id" ]]; then
    local stream_path
    stream_path="$(stream_file "$session_id")"
    mkdir -p "$(dirname "$stream_path")"
    cp "$temp_stream" "$stream_path"
  fi

  if $RAW_JSON; then
    normalized_exec_json "$temp_stream"
  else
    extract_last_text_stream "$temp_stream"
  fi

  rm -f "$temp_raw" "$temp_stream"
  return "$exit_code"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      RAW_JSON=true
      shift
      ;;
    --cwd)
      CWD_OVERRIDE="${2:-}"
      if [[ -z "$CWD_OVERRIDE" ]]; then
        echo "Error: --cwd requires a path" >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  usage
  exit 0
fi

mode="$1"
shift

case "$mode" in
  exec)
    run_exec "$@"
    ;;
  last)
    need_command jq
    sid="$(resolve_session_id "${1:-}")"
    if stream="$(resolve_stream_file "$sid" 2>/dev/null)"; then
      extract_last_text_stream "$stream"
    else
      transcript="$(resolve_transcript_file "$sid")"
      extract_last_text_transcript "$transcript"
    fi
    ;;
  messages)
    need_command jq
    sid="$(resolve_session_id "${1:-}")"
    if stream="$(resolve_stream_file "$sid" 2>/dev/null)"; then
      extract_messages_stream "$stream"
    else
      transcript="$(resolve_transcript_file "$sid")"
      extract_messages_transcript "$transcript"
    fi
    ;;
  session-id)
    resolve_session_id "${1:-}"
    ;;
  session-file)
    resolve_transcript_file "${1:-}"
    ;;
  stream-file)
    resolve_stream_file "${1:-}"
    ;;
  tools)
    need_command jq
    sid="$(resolve_session_id "${1:-}")"
    if stream="$(resolve_stream_file "$sid" 2>/dev/null)"; then
      extract_tools_stream "$stream"
    else
      input="$(resolve_transcript_file "$sid")"
      jq -c 'select(.role=="assistant") | .message.content[]? | select(.type=="tool_use") | {tool: .name, input: .input}' "$input"
    fi
    ;;
  commands)
    need_command jq
    input="$(resolve_stream_file "${1:-}")"
    jq -sc '
      def started:
        [ .[]
          | select(.type=="tool_call" and .subtype=="started" and .tool_call.shellToolCall != null)
          | {key: .call_id, value: {cmd: .tool_call.shellToolCall.args.command, desc: .tool_call.shellToolCall.args.description}}
        ] | from_entries;
      def completed:
        [ .[]
          | select(.type=="tool_call" and .subtype=="completed" and .tool_call.shellToolCall != null)
          | {
              key: .call_id,
              value: (
                if .tool_call.shellToolCall.result.success != null then
                  {
                    status: "success",
                    exit: .tool_call.shellToolCall.result.success.exitCode,
                    stdout: .tool_call.shellToolCall.result.success.stdout,
                    stderr: .tool_call.shellToolCall.result.success.stderr,
                    out: .tool_call.shellToolCall.result.success.interleavedOutput
                  }
                elif .tool_call.shellToolCall.result.rejected != null then
                  {
                    status: "rejected",
                    exit: null,
                    stdout: null,
                    stderr: null,
                    out: null,
                    reason: .tool_call.shellToolCall.result.rejected.reason,
                    is_readonly: .tool_call.shellToolCall.result.rejected.isReadonly
                  }
                else
                  {}
                end
              )
            }
        ] | from_entries;
      (started) as $started
      | (completed) as $completed
      | ($started | keys[]) as $id
      | ($started[$id] + ($completed[$id] // {}))
    ' "$input"
    ;;
  reasoning)
    need_command jq
    input="$(resolve_stream_file "${1:-}")"
    jq -r 'select(.type=="assistant") | .message.content[]? | select(.type=="thinking") | .text // .thinking' "$input"
    ;;
  usage)
    need_command jq
    sid="$(resolve_session_id "${1:-}")"
    if stream="$(resolve_stream_file "$sid" 2>/dev/null)"; then
      jq -sc '[.[] | select(.type=="result") | .usage] | last // {}' "$stream"
    else
      printf '{}\n'
    fi
    ;;
  summary)
    need_command jq
    sid="$(resolve_session_id "${1:-}")"
    stream="$(resolve_stream_file "$sid" 2>/dev/null || true)"
    transcript="$(resolve_transcript_file "$sid" 2>/dev/null || true)"
    echo "SESSION: $sid"
    if [[ -n "$stream" ]]; then
      echo "MODEL: $(jq -rs '[.[] | select(.type=="system" and .subtype=="init") | .model] | last // empty' "$stream")"
      echo "USAGE: $(jq -sc '[.[] | select(.type=="result") | .usage] | last // {}' "$stream")"
    else
      echo "MODEL: "
      echo "USAGE: {}"
    fi
    echo "---"
    if [[ -n "$stream" && -f "$stream" ]]; then
      extract_last_text_stream "$stream"
    else
      extract_last_text_transcript "$transcript"
    fi
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    usage >&2
    exit 1
    ;;
esac
